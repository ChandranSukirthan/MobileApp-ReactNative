{
  "compilerOptions": {
    "strict": false,
    "allowJs": true,
    "jsx": "react-native",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "noEmit": true,
    "target": "esnext",
    "lib": ["esnext"],
    "skipLibCheck": true
  },
  "include": [
    "src/**/*",
    "App.jsx",
    "index.js"
  ],
  "exclude": [
    "node_modules"
  ]
}